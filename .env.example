NODE_ENV=development
PORT=4000
GEMINI_API_KEY=

# PostgreSQL — required when vectorStore.provider or catalog.provider = "postgres"
# Local Docker:   postgresql://postgres:postgres@localhost:5432/policybuddies
# Supabase:       postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# AWS RDS:        postgresql://[user]:[pass]@[host]:5432/[dbname]?sslmode=require
DATABASE_URL=
DATABASE_SSL=false      # set to "true" for Supabase and AWS RDS
DATABASE_POOL_MAX=10    # lower to 5 on Supabase free tier

# CORS — restrict to your frontend origin in production
ALLOWED_ORIGIN=*

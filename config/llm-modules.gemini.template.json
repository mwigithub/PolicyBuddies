{
  "note": "Template only. Copy blocks from here into llm-modules.json to switch to Gemini.",
  "conversationLlm": {
    "provider": "gemini-conversation-provider",
    "model": "gemini-2.0-flash",
    "apiKeyEnv": "GEMINI_API_KEY"
  },
  "intentRouting": {
    "provider": "gemini-intent-router-provider",
    "model": "gemini-2.0-flash",
    "apiKeyEnv": "GEMINI_API_KEY"
  },
  "queryPlannerLlm": {
    "provider": "gemini-query-planner-provider",
    "model": "gemini-2.0-flash",
    "apiKeyEnv": "GEMINI_API_KEY"
  },
  "checkerLlm": {
    "note": "Optional: keep disabled unless checker agent gets Gemini support.",
    "enabled": false
  },
  "confidenceReview": {
    "provider": "gemini-review-provider",
    "model": "gemini-2.0-flash",
    "apiKeyEnv": "GEMINI_API_KEY",
    "independentFromIntent": true,
    "debug": true,
    "debugLogPath": "logs/gemini-review.log"
  }
}

{
  "sourceIngestion": {
    "provider": "default-ingestion-provider",
    "model": "rule-based-v1"
  },
  "conversation": {
    "provider": "default-conversation-provider",
    "model": "stub-conversation-v1"
  },
  "conversationLlm": {
    "provider": "gemini-conversation-provider",
    "model": "gemini-2.0-flash",
    "apiKeyEnv": "GEMINI_API_KEY"
  },
  "intentRouting": {
    "provider": "gemini-intent-router-provider",
    "model": "gemini-2.0-flash",
    "apiKeyEnv": "GEMINI_API_KEY"
  },
  "queryPlannerLlm": {
    "provider": "gemini-query-planner-provider",
    "model": "gemini-2.0-flash",
    "apiKeyEnv": "GEMINI_API_KEY"
  },
  "checkerLlm": {
    "enabled": false
  },
  "confidenceReview": {
    "provider": "gemini-review-provider",
    "model": "gemini-2.0-flash",
    "apiKeyEnv": "GEMINI_API_KEY",
    "independentFromIntent": true,
    "debug": true,
    "debugLogPath": "logs/gemini-review.log"
  },
  "embedding": {
    "provider": "gemini-embedding-provider",
    "model": "text-embedding-004"
  },
  "semanticEmbedding": {
    "model": "all-MiniLM-L6-v2",
    "semanticWeight": 0.6
  }
}
